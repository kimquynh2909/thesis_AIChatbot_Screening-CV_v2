# Copy this file to .env and set only the keys you actually use.

# Optional Gemini LLM explanations and chatbot.
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional Google embedding model.
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001

# Local embedding models. These are downloaded by sentence-transformers on first use.
SBERT_MODEL=sentence-transformers/all-MiniLM-L6-v2
E5_MODEL=intfloat/e5-base-v2
BGE_MODEL=BAAI/bge-base-en-v1.5

# Static embedding baselines. Leave *_PATH empty to download via gensim-data on first use.
WORD2VEC_MODEL=word2vec-google-news-300
GLOVE_MODEL=glove-wiki-gigaword-100
WORD2VEC_PATH=data/embeddings/GoogleNews-vectors-negative300.bin
GLOVE_PATH=

# Optional Qdrant vector database for RAG preparation.
# Leave QDRANT_URL empty to use local embedded Qdrant storage.
RAG_EMBEDDING_MODEL=intfloat/e5-base-v2
QDRANT_URL=https://c4a128bd-7522-43e4-be4e-d26e946719d1.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhY2Nlc3MiOiJtIiwic3ViamVjdCI6ImFwaS1rZXk6NmM4NzRjYjgtMGMxOC00OWM2LTgxNTQtMmE4ZDVjYTdkMmQyIn0.-6OtzDoC6V4ftQwPtd0h8xqYU9s42cKpraZYGnt5Zu0
QDRANT_COLLECTION=resume_rag_chunks
#QDRANT_LOCAL_PATH=outputs/qdrant_local

# Kaggle API is configured through ~/.kaggle/kaggle.json or env vars.
KAGGLE_USERNAME=
KAGGLE_KEY=
